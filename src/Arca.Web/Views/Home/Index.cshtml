@{
    ViewData["Title"] = "Arca Admin";
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Arca Admin</title>
    <style>
        body {
            margin: 0;
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #f4f6f8;
            color: #1f2933;
        }

        header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 28px;
            border-bottom: 1px solid #d7dee5;
            background: #ffffff;
        }

        h1 {
            font-size: 20px;
            margin: 0;
            letter-spacing: 0;
        }

        main {
            padding: 32px 28px;
        }

        button {
            border: 1px solid #b8c2cc;
            background: #ffffff;
            border-radius: 6px;
            padding: 9px 12px;
            font: inherit;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <header>
        <h1>Arca Admin</h1>
        <form method="post" action="/logout">
            @Html.AntiForgeryToken()
            <button type="submit">Sign out</button>
        </form>
    </header>
    <main>
        <p>Signed in as <strong>@User.Identity?.Name</strong>.</p>
    </main>
</body>
</html>
