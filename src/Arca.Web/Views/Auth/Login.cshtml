@model Arca.Web.Models.LoginViewModel

@{
    Layout = null;
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Arca Admin Login</title>
    <style>
        :root {
            color-scheme: light;
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #f4f6f8;
            color: #1f2933;
        }

        body {
            min-height: 100vh;
            margin: 0;
            display: grid;
            place-items: center;
        }

        main {
            width: min(420px, calc(100vw - 32px));
            background: #ffffff;
            border: 1px solid #d7dee5;
            border-radius: 8px;
            box-shadow: 0 20px 60px rgb(31 41 51 / 12%);
            padding: 32px;
        }

        h1 {
            margin: 0 0 8px;
            font-size: 28px;
            font-weight: 750;
            letter-spacing: 0;
        }

        p {
            margin: 0 0 28px;
            color: #5f6b7a;
            line-height: 1.5;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 650;
            font-size: 14px;
        }

        input {
            box-sizing: border-box;
            width: 100%;
            border: 1px solid #b8c2cc;
            border-radius: 6px;
            padding: 12px 14px;
            font: inherit;
            margin-bottom: 18px;
        }

        input:focus {
            outline: 3px solid #c8e6dc;
            border-color: #007a5a;
        }

        button {
            width: 100%;
            border: 0;
            border-radius: 6px;
            background: #007a5a;
            color: #ffffff;
            padding: 12px 16px;
            font: inherit;
            font-weight: 750;
            cursor: pointer;
        }

        .validation-summary-errors {
            border: 1px solid #d14343;
            background: #fff4f2;
            color: #8f1f1f;
            border-radius: 6px;
            padding: 12px 14px;
            margin-bottom: 18px;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 18px;
        }
    </style>
</head>
<body>
    <main>
        <h1>Arca</h1>
        <p>Sign in to the admin panel.</p>

        <form method="post" action="/login">
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.ReturnUrl)
            @Html.ValidationSummary(excludePropertyErrors: true)

            <label for="Email">Email</label>
            <input id="Email" name="Email" type="email" value="@Model.Email" autocomplete="email" required />

            <label for="Password">Password</label>
            <input id="Password" name="Password" type="password" autocomplete="current-password" required />

            <button type="submit">Sign in</button>
        </form>
    </main>
</body>
</html>
