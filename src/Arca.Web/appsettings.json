{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=arca;Username=postgres;Password=postgres"
  },
  "Authentication": {
    "CookieName": "Arca.Admin",
    "ExpireMinutes": 480
  },
  "Database": {
    "ApplyMigrationsOnStartup": false,
    "CreateDatabaseIfMissing": false
  },
  "Secrets": {
    "KeyPerFile": {
      "Enabled": true,
      "Path": "/run/secrets"
    }
  },
  "Security": {
    "MaxRequestBodyBytes": 10485760,
    "RequestHeadersTimeoutSeconds": 15
  },
  "RateLimiting": {
    "Admin": {
      "PermitLimit": 300,
      "WindowMinutes": 1
    },
    "Auth": {
      "PermitLimit": 20,
      "WindowMinutes": 1
    }
  },
  "Storage": {
    "Provider": "S3",
    "Local": {
      "BasePath": "wwwroot/uploads",
      "PublicBaseUrl": "/uploads"
    },
    "S3": {
      "BucketName": "",
      "Region": "us-east-1",
      "ServiceUrl": "",
      "ForcePathStyle": true,
      "AccessKey": "",
      "SecretKey": "",
      "PublicBaseUrl": ""
    }
  },
  "Seed": {
    "SuperAdmin": {
      "Enabled": false
    }
  }
}
