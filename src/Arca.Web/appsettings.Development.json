{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=arca;Username=postgres;Password=postgres"
  },
  "Authentication": {
    "CookieName": "Arca.Admin.Dev",
    "ExpireMinutes": 480
  },
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "CreateDatabaseIfMissing": true
  },
  "Secrets": {
    "KeyPerFile": {
      "Enabled": false,
      "Path": "/run/secrets"
    }
  },
  "Security": {
    "MaxRequestBodyBytes": 10485760,
    "RequestHeadersTimeoutSeconds": 15
  },
  "RateLimiting": {
    "Admin": {
      "PermitLimit": 600,
      "WindowMinutes": 1
    },
    "Auth": {
      "PermitLimit": 60,
      "WindowMinutes": 1
    }
  },
  "Storage": {
    "Provider": "Local",
    "Local": {
      "BasePath": "wwwroot/uploads",
      "PublicBaseUrl": "/uploads"
    },
    "S3": {
      "BucketName": "",
      "Region": "us-east-1",
      "ServiceUrl": "",
      "ForcePathStyle": true,
      "AccessKey": "",
      "SecretKey": "",
      "PublicBaseUrl": ""
    }
  },
  "Seed": {
    "SuperAdmin": {
      "Enabled": true,
      "FullName": "Arca Super Admin",
      "Email": "admin@arca.local",
      "Password": "ChangeMe!12345"
    }
  }
}
