{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=arca;Username=postgres;Password=postgres"
  },
  "Secrets": {
    "KeyPerFile": {
      "Enabled": true,
      "Path": "/run/secrets"
    }
  },
  "Security": {
    "MaxRequestBodyBytes": 1048576,
    "RequestHeadersTimeoutSeconds": 15
  },
  "RateLimiting": {
    "ExternalApi": {
      "PermitLimit": 120,
      "WindowMinutes": 1
    }
  }
}
