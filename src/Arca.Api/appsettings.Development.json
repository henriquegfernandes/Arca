{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=arca;Username=postgres;Password=postgres"
  },
  "Secrets": {
    "KeyPerFile": {
      "Enabled": false,
      "Path": "/run/secrets"
    }
  },
  "Security": {
    "MaxRequestBodyBytes": 1048576,
    "RequestHeadersTimeoutSeconds": 15
  },
  "RateLimiting": {
    "ExternalApi": {
      "PermitLimit": 300,
      "WindowMinutes": 1
    }
  }
}
