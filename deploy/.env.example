# =============================================================================
# Arca — variáveis de ambiente para produção
#
# 1. Copie este arquivo:  cp .env.example .env
# 2. Preencha cada valor
# 3. Nunca commite o .env no repositório
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

# Nome do banco de dados
POSTGRES_DB=arca_prod

# Usuário do banco — o container cria automaticamente na primeira subida
POSTGRES_USER=arca_app

# Senha do banco — use no mínimo 20 caracteres
POSTGRES_PASSWORD=


# -----------------------------------------------------------------------------
# Minio (S3-compatible storage)
# -----------------------------------------------------------------------------

# Usuário root do Minio (equivalente ao Access Key ID)
MINIO_ROOT_USER=minioadmin

# Senha root do Minio — use no mínimo 16 caracteres
MINIO_ROOT_PASSWORD=

# Nome do bucket onde as imagens de produto serão armazenadas
MINIO_BUCKET=arca-uploads

# URL pública pela qual os arquivos do bucket são acessados.
# Configure o Nginx para fazer proxy desta rota para http://localhost:9000/<bucket>.
# Exemplo: https://arca.seudominio.com/storage
STORAGE_PUBLIC_URL=https://arca.seudominio.com/storage


# -----------------------------------------------------------------------------
# Arca — aplicação
# -----------------------------------------------------------------------------

# URL pública do admin (usada nos links de e-mail de convite)
APP_BASE_URL=https://arca.seudominio.com

# Credenciais do primeiro superadmin criado na primeira subida.
# Após o primeiro login, altere a senha imediatamente.
ADMIN_EMAIL=admin@arca.local
ADMIN_PASSWORD=


# -----------------------------------------------------------------------------
# E-mail SMTP (opcional)
# Deixe SMTP_HOST vazio para desativar o envio de e-mails.
# Quando configurado, e-mails de convite são enviados ao criar novos tenants.
# -----------------------------------------------------------------------------

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@arca.app
